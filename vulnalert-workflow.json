{
  "name": "VulnAlert Bot",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "vulnalert",
        "responseMode": "lastNode"
      }
    },
    {
      "name": "IF",
      "type": "n8n-nodes-base.if",
      "position": [500, 300],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.body.issue.title}}",
              "operation": "contains",
              "value2": "vulnerability"
            }
          ]
        }
      }
    },
    {
      "name": "Slack",
      "type": "n8n-nodes-base.slack",
      "position": [750, 300],
      "parameters": {
        "channel": "#security-alerts",
        "text": "🚨 SECURITY ALERT\n\n*Repo:* {{$json.body.repository.full_name}}\n*Issue:* {{$json.body.issue.title}}\n*Link:* {{$json.body.issue.html_url}}"
      }
    }
  ]
}
